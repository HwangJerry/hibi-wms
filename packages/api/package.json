{
  "name": "@hibi/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "test": "vitest run --passWithNoTests",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@hibi/config": "workspace:*",
    "tsx": "^4.22.4"
  },
  "dependencies": {
    "@hibi/auth": "workspace:*",
    "@hibi/core": "workspace:*",
    "@hibi/db": "workspace:*",
    "@trpc/server": "^11.17.0",
    "fastify": "^5.8.5",
    "zod": "^4.4.3"
  }
}
