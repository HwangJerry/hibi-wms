generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String
  passwordHash String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  sessions     Session[]
  tasks        Task[]
  pageVersions PageVersion[]
}

model Session {
  id        String   @id
  userId    String
  expiresAt DateTime
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([expiresAt])
}

enum EntityType {
  TASK
  APPROVAL
  TRANSACTION
  PAGE
  COMMENT
  ATTACHMENT
}

enum NotificationType {
  APPROVAL_PENDING
  TASK_ASSIGNED
  TASK_MENTION
}

enum ApprovalType {
  FINANCIAL
  WORK
}

enum ApprovalState {
  DRAFT
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum ApprovalActionKind {
  SUBMIT
  APPROVE
  REJECT
  CANCEL
  COMMENT
}

model Reference {
  id        String     @id @default(cuid())
  fromType  EntityType
  fromId    String
  toType    EntityType
  toId      String
  relation  String     @default("__unlabeled__")
  createdAt DateTime   @default(now())

  @@unique([fromType, fromId, toType, toId, relation])
  @@index([toType, toId])
}

model AuditLog {
  id         String     @id @default(cuid())
  actorId    String
  action     String
  entityType EntityType
  entityId   String
  data       Json
  createdAt  DateTime   @default(now())

  @@index([entityType, entityId])
}

model Comment {
  id        String   @id @default(cuid())
  authorId  String
  body      String
  createdAt DateTime @default(now())
}

model Attachment {
  id         String   @id @default(cuid())
  uploaderId String
  fileName   String
  mimeType   String
  sizeBytes  Int
  r2Key      String
  createdAt  DateTime @default(now())
}

model ApprovalRequest {
  id          String         @id @default(cuid())
  type        ApprovalType
  title       String
  description String?
  requesterId String
  approverId  String
  state       ApprovalState  @default(PENDING)
  decidedAt   DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  actions     ApprovalAction[]
  transactions Transaction[] @relation("ApprovalTransactions")
}

model ApprovalAction {
  id        String              @id @default(cuid())
  requestId String
  actorId   String
  action    ApprovalActionKind
  note      String?
  createdAt DateTime            @default(now())
  request   ApprovalRequest     @relation(fields: [requestId], references: [id])
}

enum AccountKind {
  CASH
  BANK
  CARD
  OTHER
}

enum CategoryKind {
  INCOME
  EXPENSE
}

enum TxStatus {
  PENDING
  POSTED
  REVERSED
}

model Account {
  id        String     @id @default(cuid())
  name      String
  kind      AccountKind
  currency  String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  transactions Transaction[]
}

model Category {
  id        String       @id @default(cuid())
  name      String
  kind      CategoryKind
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  transactions Transaction[]
  budgets    Budget[]
}

model Transaction {
  id           String     @id @default(cuid())
  accountId    String
  categoryId   String?
  amount       Decimal    @db.Decimal(18, 2)
  currency     String
  description  String?
  status       TxStatus   @default(PENDING)
  approvalId   String?
  occurredAt   DateTime
  postedAt     DateTime?
  reversedById String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  account      Account    @relation(fields: [accountId], references: [id], onDelete: Restrict)
  category     Category?  @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  approval     ApprovalRequest? @relation("ApprovalTransactions", fields: [approvalId], references: [id], onDelete: SetNull)
  reversedBy   Transaction? @relation("TransactionReversal", fields: [reversedById], references: [id], onDelete: SetNull)
  reversed     Transaction[] @relation("TransactionReversal")

  @@index([accountId])
  @@index([categoryId])
  @@index([status])
  @@index([approvalId])
  @@index([reversedById])
  @@index([occurredAt])
}

model Notification {
  id         String           @id @default(cuid())
  recipientId String
  actorId    String
  type       NotificationType
  entityType EntityType
  entityId   String
  title      String
  message    String?
  targetPath String?
  isRead     Boolean          @default(false)
  readAt     DateTime?
  createdAt  DateTime         @default(now())

  @@index([recipientId, createdAt])
  @@index([recipientId, isRead])
}

model Budget {
  id          String    @id @default(cuid())
  categoryId  String
  periodStart DateTime
  periodEnd   DateTime
  limit       Decimal   @db.Decimal(18, 2)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  category    Category  @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  @@index([categoryId])
  @@index([periodStart, periodEnd])
}

enum TaskStatus {
  BACKLOG
  TODO
  IN_PROGRESS
  IN_REVIEW
  BLOCKED
  DONE
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model Task {
  id          String     @id @default(cuid())
  title       String
  description String?
  status      TaskStatus @default(BACKLOG)
  priority    Priority   @default(MEDIUM)
  assigneeId  String?
  parentId    String?
  order       Float
  deletedAt   DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  assignee    User?      @relation(fields: [assigneeId], references: [id])
  parent      Task?      @relation("TaskEpic", fields: [parentId], references: [id])
  children    Task[]     @relation("TaskEpic")

  @@index([status, order])
  @@index([assigneeId])
  @@index([parentId, order])
  @@index([deletedAt])
}

model Space {
  id         String     @id @default(cuid())
  name       String
  deletedAt  DateTime?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  pages      Page[]
}

model Page {
  id         String     @id @default(cuid())
  spaceId    String
  parentId   String?
  title      String
  yDoc       Bytes
  textProjection String  @default("")
  order      Float
  deletedAt  DateTime?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  space      Space      @relation(fields: [spaceId], references: [id])
  parent     Page?      @relation("PageTree", fields: [parentId], references: [id], onDelete: SetNull)
  children   Page[]     @relation("PageTree")
  versions   PageVersion[]

  @@index([spaceId])
  @@index([parentId, order])
  @@index([deletedAt])
}

model PageVersion {
  id        String   @id @default(cuid())
  pageId    String
  yDoc      Bytes
  authorId  String
  label     String?
  createdAt DateTime @default(now())
  page      Page     @relation(fields: [pageId], references: [id], onDelete: Cascade)
  author    User     @relation(fields: [authorId], references: [id])

  @@index([pageId])
  @@index([authorId])
  @@index([createdAt])
}
