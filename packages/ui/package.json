{
  "name": "@hibi/ui",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    },
    "./tokens/tailwind-preset": {
      "types": "./dist/tokens/tailwind-preset.d.ts",
      "default": "./dist/tokens/tailwind-preset.js"
    },
    "./tokens/tokens.css": "./tokens/tokens.css",
    "./tokens/tokens.json": "./tokens/tokens.json"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "catalog:build": "ladle build --config .ladle",
    "catalog:dev": "ladle serve --config .ladle --host 127.0.0.1",
    "test": "vitest run --passWithNoTests",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "peerDependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": false
    },
    "react-dom": {
      "optional": false
    }
  },
  "devDependencies": {
    "@hibi/config": "workspace:*",
    "@ladle/react": "^5.1.1",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "autoprefixer": "^10.5.0",
    "lucide-react": "^1.20.0",
    "postcss": "^8.5.15",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.19"
  }
}
