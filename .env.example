# Local Docker Compose Postgres. Keep this password local and do not commit it.
POSTGRES_USER="hibi"
POSTGRES_PASSWORD="<local-password>"
POSTGRES_DB="hibi_portal"
POSTGRES_PORT="5432"
DATABASE_URL="postgresql://hibi:<local-password>@127.0.0.1:5432/hibi_portal?schema=public"

# Optional host-reachable endpoint for Postgres running in the connected k3s cluster.
# The default manifest exposes Postgres on server-main's Tailscale IP via NodePort 30432.
# DATABASE_URL="postgresql://hibi:<password>@100.74.225.115:30432/hibi_portal?schema=public"
