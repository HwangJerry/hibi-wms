{
  "name": "hibi-portal",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.28.2",
  "engines": {
    "node": ">=20 <24"
  },
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:migrate": "pnpm --filter @hibi/db db:migrate",
    "db:studio": "pnpm --filter @hibi/db db:studio",
    "db:seed": "pnpm --filter @hibi/db db:seed"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@hibi/config": "workspace:*",
    "@types/node": "^20.19.25",
    "eslint": "^9.39.1",
    "prettier": "^3.7.4",
    "turbo": "^2.6.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.50.0",
    "vitest": "^4.0.15"
  }
}
