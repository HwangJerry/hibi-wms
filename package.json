{
  "name": "hibi-portal",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.28.2",
  "engines": {
    "node": ">=20.19 <24"
  },
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:postgres": "docker compose up -d postgres",
    "tokens:extract": "node scripts/extract-tokens.js",
    "tokens:build": "node scripts/build-tokens.js",
    "build": "turbo run build",
    "test": "turbo run test",
    "e2e": "playwright test",
    "e2e:ci": "playwright test --reporter=dot",
    "visual:seed": "tsx scripts/seed-visual-fixtures.ts",
    "visual:parity": "node -e \"const fs=require('fs'); fs.rmSync('docs/visual-parity-report.md',{force:true}); fs.rmSync('test-results/visual-parity/report.jsonl',{force:true});\" && pnpm tokens:extract && pnpm tokens:build && pnpm --filter @hibi/db exec prisma migrate deploy --config prisma.config.ts && pnpm --filter @hibi/db build && pnpm visual:seed && playwright test -c playwright.visual.config.ts",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:migrate": "pnpm --filter @hibi/db db:migrate",
    "db:studio": "pnpm --filter @hibi/db db:studio",
    "db:seed": "pnpm --filter @hibi/db db:seed"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@hibi/config": "workspace:*",
    "@playwright/test": "^1.61.0",
    "@types/node": "^20.19.25",
    "@types/pngjs": "^6.0.5",
    "eslint": "^9.39.1",
    "pixelmatch": "^7.2.0",
    "pngjs": "^7.0.0",
    "prettier": "^3.7.4",
    "tsx": "^4.22.4",
    "turbo": "^2.6.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.50.0",
    "vitest": "^4.0.15"
  }
}
